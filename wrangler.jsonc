{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "landing-page",
  "main": "worker.js",
  "compatibility_date": "2026-04-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "ALLOWED_ORIGINS": "https://lokeshtewari.uk"
  },
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT_KV",
      "id": "1f01369147a6438d95824abcb8d89126"
    }
  ]
}
